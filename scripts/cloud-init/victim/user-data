#cloud-config
# Victim VM — first-boot configuration via cloud-init.
# Placeholders (__VAR__) are replaced by setup_victim.sh using sed.

hostname: wlkom-victim

locale: fr_FR.UTF-8
timezone: Europe/Paris

keyboard:
  layout: fr
  variant: ""

users:
  - name: __VM_USER__
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    groups: sudo
    lock_passwd: false

ssh_pwauth: true

chpasswd:
  list: |
    __VM_USER__:__VM_PASS__
  expire: false

packages:
  - build-essential
  - gcc
  - make
  - linux-headers-amd64
  - git
  - openssh-server
  - kmod
  - curl
  - wget

package_update: true
package_upgrade: false

runcmd:
  - systemctl enable ssh
  - systemctl start ssh

#cloud-config
# Attacker VM — first-boot configuration via cloud-init.
# Placeholders (__VAR__) are replaced by setup_attacker.sh using sed.

hostname: wlkom-attacker

locale: en_US.UTF-8
timezone: UTC

users:
  - name: __VM_USER__
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    groups: sudo
    lock_passwd: false
    ssh_authorized_keys:
      - __SSH_PUBKEY__

# Allow SSH password authentication (needed since we don't inject SSH keys here)
ssh_pwauth: true

chpasswd:
  list: |
    __VM_USER__:__VM_PASS__
  expire: false

packages:
  - build-essential
  - gcc
  - make
  - netcat-openbsd
  - git
  - openssh-server
  - curl
  - wget
  - python3
  - wireshark
  - tshark
  - kbd
  - console-setup

package_update: true
package_upgrade: false

runcmd:
  - systemctl enable ssh
  - systemctl start ssh
  - echo "wireshark-common wireshark-common/install-setuid boolean true" | debconf-set-selections
  - dpkg-reconfigure -f noninteractive wireshark-common
  - usermod -aG wireshark __VM_USER__
